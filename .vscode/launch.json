{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "1. Generate Data + Train",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/train_federated.py",
            "console": "integratedTerminal"
        },
        {
            "name": "2. Start Flask API",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/api.py",
            "console": "integratedTerminal",
            "env": {
                "FLASK_DEBUG": "true"
            }
        },
        {
            "name": "3. Start Streamlit UI",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "app.py"],
            "console": "integratedTerminal"
        },
        {
            "name": "Data Generator Only",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/data_generator.py",
            "console": "integratedTerminal"
        }
    ]
}
